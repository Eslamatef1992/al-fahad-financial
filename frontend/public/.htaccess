<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Never cache index.html — always fetch fresh so a new deploy is picked up immediately.
  # This is what was causing the white-page-until-refresh / stale-JS bugs: the browser was
  # serving an old cached index.html that pointed at hashed JS/CSS files from a previous
  # build which no longer existed (or no longer matched), causing broken images and
  # "X is not a function" errors until a hard refresh forced a fresh index.html.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  # Hashed JS/CSS/asset filenames change on every build, so these are safe to cache long-term.
  <FilesMatch "\.(js|css|svg|png|jpg|jpeg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
